{
  "manifest_version": 3,
  "name": "LeetCode Notes Sync",
  "version": "1.0",
  "description": "每天自动同步 LeetCode 已做题目到本地笔记系统",
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode Notes Sync"
  }
}
